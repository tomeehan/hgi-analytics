#!/usr/bin/env bash
# bin/setup — bootstrap a fresh checkout of hgi-analytics for local development.
#
# Supports: macOS (Homebrew) and Ubuntu 24.04 (bothy remote servers).
# Idempotent. Safe to re-run.
#
# What it does:
#   1. Detects platform; on Linux, apt-get installs python3 + venv if missing.
#   2. Verifies prerequisites (git, python3 ≥ 3.9).
#   3. Creates a Python venv at .venv/ and installs dbt-snowflake + snowflake-cli + requests.
#   4. Runs `dbt deps` to fetch dbt packages.
#   5. Scaffolds dbt/profiles.yml + .env from templates if missing.
#   6. On Linux (bothy): symlinks ~/.snowflake/config.toml -> .snowflake/config.toml,
#      writes ~/.ssh/config aliases for hgi-airbyte / hgi-lightdash.
#
# Usage:  ./bin/setup           # full setup
#         ./bin/setup --check   # only verify prerequisites, don't install

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

PLATFORM="$(uname -s)"

# ── output helpers ──────────────────────────────────────────────────────────
if [ -t 1 ]; then
  BOLD=$(printf '\033[1m'); DIM=$(printf '\033[2m'); RED=$(printf '\033[31m')
  GREEN=$(printf '\033[32m'); YELLOW=$(printf '\033[33m'); RESET=$(printf '\033[0m')
else
  BOLD=""; DIM=""; RED=""; GREEN=""; YELLOW=""; RESET=""
fi
step()  { printf "\n${BOLD}==> %s${RESET}\n" "$*"; }
ok()    { printf "  ${GREEN}✓${RESET} %s\n" "$*"; }
warn()  { printf "  ${YELLOW}!${RESET} %s\n" "$*"; }
fail()  { printf "  ${RED}✗${RESET} %s\n" "$*" >&2; }
info()  { printf "  ${DIM}%s${RESET}\n" "$*"; }

CHECK_ONLY=0
[ "${1:-}" = "--check" ] && CHECK_ONLY=1

case "$PLATFORM" in
  Darwin) ok "Platform: macOS" ;;
  Linux)  ok "Platform: Linux (Ubuntu/bothy)" ;;
  *)      fail "Unsupported OS: $PLATFORM"; exit 1 ;;
esac

# ── Linux: install python3 + venv via apt if missing (bothy runs as root) ───
# Ubuntu splits python3 into multiple packages: the `venv` module is in stdlib,
# but `ensurepip` (which `python3 -m venv` requires to bootstrap pip) ships in
# python3-venv. So we check for `ensurepip`, not `venv`. Same goes for pip.
if [ "$PLATFORM" = "Linux" ] && [ "$CHECK_ONLY" -eq 0 ]; then
  if ! command -v python3 >/dev/null 2>&1 \
     || ! python3 -c 'import ensurepip' 2>/dev/null \
     || ! python3 -c 'import pip' 2>/dev/null; then
    step "Installing python3 + python3-venv + python3-pip via apt"
    apt-get update -qq
    apt-get install -y -qq python3 python3-venv python3-pip
    ok "python3 + venv + pip installed"
  fi
fi

# ── prerequisites ───────────────────────────────────────────────────────────
step "Checking prerequisites"

MISSING=0
need() {
  local cmd="$1" hint="$2"
  if command -v "$cmd" >/dev/null 2>&1; then
    ok "$cmd ($(command -v "$cmd"))"
  else
    fail "$cmd not found — $hint"
    MISSING=1
  fi
}

if [ "$PLATFORM" = "Darwin" ]; then
  need git     "install Xcode Command Line Tools (xcode-select --install)"
  need python3 "brew install python@3.11"
else
  need git     "apt-get install -y git"
  need python3 "apt-get install -y python3 python3-venv"
fi

# Python version: dbt-snowflake 1.11 needs Python 3.9+
PY_VERSION=$(python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])')
PY_MAJOR=${PY_VERSION%.*}; PY_MINOR=${PY_VERSION#*.}
if [ "$PY_MAJOR" -lt 3 ] || { [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 9 ]; }; then
  fail "Python $PY_VERSION is too old — need 3.9+"
  MISSING=1
else
  ok "python3 version $PY_VERSION"
fi

# Optional CLIs — warn but don't fail. These are managed-separately tools
# (Homebrew/curl installs); we don't try to apt-get them on Linux.
optional() {
  local cmd="$1" purpose="$2"
  if command -v "$cmd" >/dev/null 2>&1; then
    ok "$cmd (optional, $purpose)"
  else
    warn "$cmd not installed — $purpose. See CLAUDE.md → CLIs."
  fi
}
optional gh        "GitHub CLI"
optional snow      "Snowflake CLI for ad-hoc queries"
optional hcloud    "Hetzner Cloud CLI"
optional neonctl   "Neon Postgres CLI"

if [ "$MISSING" -eq 1 ]; then
  fail "Missing required tools — install the above and re-run."
  exit 1
fi

if [ "$CHECK_ONLY" -eq 1 ]; then
  step "Check complete"
  exit 0
fi

# ── Python venv ─────────────────────────────────────────────────────────────
step "Creating Python virtualenv at .venv/"
if [ ! -d .venv ]; then
  python3 -m venv .venv
  ok "Created .venv/"
else
  ok ".venv/ already exists"
fi

# shellcheck disable=SC1091
source .venv/bin/activate
python -m pip install --quiet --upgrade pip
ok "pip upgraded"

step "Installing dbt-snowflake from dbt/requirements.txt"
pip install --quiet -r dbt/requirements.txt
ok "$(dbt --version 2>&1 | head -1)"

# `requests` is used by lightdash/build_*.py scripts.
step "Installing helper Python deps (requests)"
pip install --quiet requests
ok "requests installed"

# `snow` CLI for ad-hoc Snowflake SQL (snowflake-cli is a Python tool, so
# the venv is the natural home for it).
step "Installing snowflake-cli (snow) into the venv"
pip install --quiet snowflake-cli
ok "$(snow --version 2>&1 | head -1)"

# ── dbt deps ────────────────────────────────────────────────────────────────
step "Fetching dbt packages"
( cd dbt && dbt deps --quiet )
ok "dbt packages installed"

# ── profiles.yml scaffold ──────────────────────────────────────────────────
step "Setting up dbt/profiles.yml"
if [ -f dbt/profiles.yml ]; then
  ok "dbt/profiles.yml already present — leaving it alone"
else
  cat > dbt/profiles.yml <<'PROFILE'
# Local dbt profile for hgi-analytics. Gitignored — fill in your password.
# Ask Tom for Snowflake credentials.
hgi:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: REPLACE_ME       # e.g. abc12345.eu-west-2.aws
      user: DBT_USER
      password: REPLACE_ME
      role: TRANSFORMER
      database: HGI
      warehouse: HGI_WH
      schema: DBT_DEV_<your-initials>   # personal dev schema
      threads: 4
      client_session_keep_alive: false
PROFILE
  ok "Wrote dbt/profiles.yml — fill in your Snowflake creds (ask Tom)"
fi

# ── .env scaffold + validation ──────────────────────────────────────────────
step "Setting up .env"
if [ ! -f .env.example ]; then
  fail ".env.example is missing — it should be checked in. Restore it before re-running."
  exit 1
fi

if [ ! -f .env ]; then
  cp .env.example .env
  ok "Copied .env.example → .env — fill in creds (ask Tom), then re-run."
  fail ".env was just created with empty values — populate it and re-run ./bin/setup."
  exit 1
fi
ok ".env present"

# Validate: every key listed in .env.example must have a non-empty value in .env.
# `|| true` is load-bearing: under `set -euo pipefail`, a missing key (grep returns 1)
# would otherwise kill the script silently mid-loop, before any error message prints.
EXAMPLE_KEYS=$(grep -E '^[A-Z_][A-Z0-9_]*=' .env.example | cut -d= -f1)
EMPTY_KEYS=()
for key in $EXAMPLE_KEYS; do
  value=$(grep -E "^${key}=" .env | head -1 | cut -d= -f2- || true)
  if [ -z "$value" ]; then
    EMPTY_KEYS+=("$key")
  fi
done
if [ "${#EMPTY_KEYS[@]}" -gt 0 ]; then
  fail ".env is missing values for: ${EMPTY_KEYS[*]}"
  info "Fill them in (ask Tom) and re-run ./bin/setup."
  exit 1
fi
ok ".env has values for all keys in .env.example"

# ── Linux (bothy): Snowflake CLI config + Hetzner SSH aliases ──────────────
# On Mac the operator's home already has ~/.snowflake/config.toml and ~/.ssh/config.
# On bothy neither exists. .bothy.yml ships .snowflake/config.toml into the
# repo; we symlink it into $HOME. SSH host aliases for hgi-airbyte and
# hgi-lightdash are written into ~/.ssh/config so chained SSH works once
# the operator has agent-forwarding enabled from their Mac.
if [ "$PLATFORM" = "Linux" ]; then
  step "Linking ~/.snowflake/config.toml -> repo .snowflake/config.toml"
  if [ -f .snowflake/config.toml ]; then
    mkdir -p "$HOME/.snowflake"
    chmod 700 "$HOME/.snowflake"
    if [ -L "$HOME/.snowflake/config.toml" ] || [ -f "$HOME/.snowflake/config.toml" ]; then
      rm -f "$HOME/.snowflake/config.toml"
    fi
    ln -s "$REPO_ROOT/.snowflake/config.toml" "$HOME/.snowflake/config.toml"
    chmod 600 "$REPO_ROOT/.snowflake/config.toml"
    ok "linked $HOME/.snowflake/config.toml"
  else
    warn ".snowflake/config.toml missing in repo. Copy from your Mac: ~/.snowflake/config.toml"
    warn "  (and re-add .snowflake/config.toml to .bothy.yml copy: if you removed it)"
  fi

  step "Writing ~/.ssh/config aliases for hgi-airbyte / hgi-lightdash"
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
  touch "$HOME/.ssh/config"
  chmod 600 "$HOME/.ssh/config"
  ssh_block_start="# >>> hgi-analytics managed: Hetzner hosts >>>"
  ssh_block_end="# <<< hgi-analytics managed: Hetzner hosts <<<"
  # Idempotent: strip any previous managed block before re-adding.
  if grep -qF "$ssh_block_start" "$HOME/.ssh/config"; then
    awk -v s="$ssh_block_start" -v e="$ssh_block_end" '
      $0 == s { skip = 1; next }
      $0 == e { skip = 0; next }
      !skip   { print }
    ' "$HOME/.ssh/config" > "$HOME/.ssh/config.tmp"
    mv "$HOME/.ssh/config.tmp" "$HOME/.ssh/config"
    chmod 600 "$HOME/.ssh/config"
  fi
  cat >> "$HOME/.ssh/config" <<SSHEOF
$ssh_block_start
Host hgi-airbyte
  HostName 49.12.68.42
  User root
  StrictHostKeyChecking accept-new

Host hgi-lightdash
  HostName 49.12.65.122
  User root
  StrictHostKeyChecking accept-new
$ssh_block_end
SSHEOF
  ok "wrote hgi-airbyte + hgi-lightdash to ~/.ssh/config"
fi

# ── final hint ─────────────────────────────────────────────────────────────
step "Setup complete"
cat <<EOF
  Next steps:
    1. Edit ${BOLD}dbt/profiles.yml${RESET} with your Snowflake password (ask Tom).
    2. Activate the venv:        ${BOLD}source .venv/bin/activate${RESET}
    3. Verify the connection:    ${BOLD}cd dbt && dbt debug${RESET}
    4. Build the project:        ${BOLD}cd dbt && dbt build${RESET}

  Ad-hoc Snowflake SQL:
    ${BOLD}snow sql -q 'select current_role()'${RESET}              # default: hgi (TRANSFORMER)
    ${BOLD}snow sql -c hgi-admin -q '...'${RESET}                    # ACCOUNTADMIN

  SSH to Hetzner VMs (from bothy):
    Aliases are written: ${BOLD}ssh hgi-airbyte${RESET} / ${BOLD}ssh hgi-lightdash${RESET}.
    This requires SSH agent forwarding from your Mac. On the Mac:
      1. Ensure your key is loaded:  ${BOLD}ssh-add ~/.ssh/id_rsa${RESET}
      2. Forward the agent when connecting to bothy. Add to ${BOLD}~/.ssh/config${RESET}:
           ${DIM}Host hgi-analytics${RESET}
           ${DIM}  ForwardAgent yes${RESET}
         or pass ${BOLD}-A${RESET} explicitly to ssh.
    For Airbyte API access, tunnel localhost:8000 over SSH:
      ${BOLD}ssh -L 8000:localhost:8000 hgi-airbyte${RESET}

  See CLAUDE.md for the full architecture and conventions.
EOF
