{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bronze.sh\"",
            "timeout": 10,
            "statusMessage": "Checking Bronze immutability"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-prod-target.sh\"",
            "timeout": 10,
            "statusMessage": "Checking dbt target"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sqlfluff-lint.sh\"",
            "timeout": 45,
            "statusMessage": "Linting dbt SQL with sqlfluff"
          }
        ]
      }
    ]
  }
}
