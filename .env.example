# Local environment for hgi-analytics. Copy to .env (gitignored) and fill in.
# Real values live in 1Password.

# Lightdash (used by lightdash/build_*.py dashboard-builder scripts)
LIGHTDASH_URL=https://lightdash.hgi.tomeehan.net
LIGHTDASH_TOKEN=
LIGHTDASH_PROJECT_UUID=
LIGHTDASH_SPACE_UUID=

# Snowflake (used by ad-hoc scripts and the `snow` CLI fallback)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=DBT_USER
SNOWFLAKE_PASSWORD=
